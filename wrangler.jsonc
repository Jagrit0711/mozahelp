{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moza-help-bot",
  "main": "src/index.ts",
  "compatibility_date": "2024-05-29",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "SUPABASE_URL": "REPLACE_WITH_SUPABASE_URL"
  },
  "observability": {
    "enabled": true
  }
}
